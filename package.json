{
  "name": "sharelist-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "ShareList Monorepo Root",
  "scripts": {
    "install:all": "npm install && npm install --prefix frontend && pip install -r backend/requirements.txt",
    "dev": "concurrently \"npm run dev --prefix frontend\" \"uvicorn backend.main:app --reload --port 8000\"",
    "build:frontend": "npm run build --prefix frontend",
    "db:backup": "python scripts/db_tool.py backup",
    "db:restore": "python scripts/db_tool.py restore",
    "test:e2e": "pytest tests/test_e2e.py",
    "test:load": "python tests/load_test.py"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
